{% extends 'base.html.twig' %}

{% block title %}{{ recipe.name }} - Marmiton{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8">
                <h1>{{ recipe.name }}</h1>
                
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="recipe-details card mb-4">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Preparation Time</h5>
                                <p class="fs-5">{{ recipe.time }} minutes</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Number of People</h5>
                                <p class="fs-5">{{ recipe.nbPeople ?? 'Not specified' }}</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Difficulty</h5>
                                <p class="fs-5">
                                    {% if recipe.difficulty %}
                                        {{ recipe.difficulty }}/5
                                    {% else %}
                                        Not specified
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h5>Price</h5>
                                <p class="fs-5">
                                    {% if recipe.price %}
                                        €{{ recipe.price }}
                                    {% else %}
                                        Not specified
                                    {% endif %}
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Favorite</h5>
                                <p class="fs-5">
                                    {% if recipe.favorite %}
                                        <span class="badge bg-success">Yes ⭐</span>
                                    {% else %}
                                        <span class="badge bg-secondary">No</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h5>Created At</h5>
                                <p class="fs-5">{{ recipe.createdAt ? recipe.createdAt|date('d/m/Y H:i') : 'N/A' }}</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <h5>Last Updated</h5>
                                <p class="fs-5">{{ recipe.updatedAt ? recipe.updatedAt|date('d/m/Y H:i') : 'N/A' }}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="description-section card mb-4">
                    <div class="card-body">
                        <h4>Description</h4>
                        <p class="lead">{{ recipe.description }}</p>
                    </div>
                </div>

                <div class="ingredients-section card mb-4">
                    <div class="card-header bg-primary">
                        <h4 class="mb-0 text-white">Ingredients</h4>
                    </div>
                    <div class="card-body">
                        {% if recipe.ingredients|length > 0 %}
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th scope="col">Name</th>
                                        <th scope="col">Price</th>
                                        <th scope="col">Created At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for ingredient in recipe.ingredients %}
                                        <tr>
                                            <td>
                                                <a href="{{ path('app_ingredient_show', {id: ingredient.id}) }}" class="text-decoration-none">
                                                    {{ ingredient.name }}
                                                </a>
                                            </td>
                                            <td>€{{ ingredient.price }}</td>
                                            <td>{{ ingredient.createdAt ? ingredient.createdAt|date('d/m/Y H:i') : 'N/A' }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <p class="alert alert-info mb-0">No ingredients added to this recipe yet.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
