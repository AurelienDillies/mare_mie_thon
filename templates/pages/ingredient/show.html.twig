{% extends 'base.html.twig' %}

{% block title %}{{ ingredient.name }} - Marmiton{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8">
                <h1>{{ ingredient.name }}</h1>
                
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="ingredient-details card mb-4">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Price</h5>
                                <p class="fs-5">€{{ ingredient.price }}</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Created At</h5>
                                <p class="fs-5">{{ ingredient.createdAt ? ingredient.createdAt|date('d/m/Y H:i') : 'N/A' }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
